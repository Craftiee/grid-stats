RewriteEngine On

# Set default index
DirectoryIndex index.php

# Remove .php extension from URLs
# Redirect /page.php to /page
RewriteCond %{THE_REQUEST} \s/([^.]+)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Don't rewrite real files or directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# API requests to router (MUST come before .php extension rule)
RewriteRule ^api/(.*)$ api/router.php?endpoint=$1 [L,QSA]

# Route /teams/team-id to teams.php
RewriteRule ^teams/?$ teams.php [L,QSA]
RewriteRule ^teams/([a-zA-Z0-9_-]+)/?$ teams.php?id=$1 [L,QSA]

# Route /drivers/driver-id to drivers.php
RewriteRule ^drivers/?$ drivers.php [L,QSA]
RewriteRule ^drivers/([a-zA-Z0-9_-]+)/?$ drivers.php?id=$1 [L,QSA]

# Route /circuits/circuit-id to circuits.php
RewriteRule ^circuits/?$ circuits.php [L,QSA]
RewriteRule ^circuits/([a-zA-Z0-9_-]+)/?$ circuits.php?id=$1 [L,QSA]

# Serve .php files without extension (including subdirectories)
# This must come LAST
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)/?$ $1.php [L]